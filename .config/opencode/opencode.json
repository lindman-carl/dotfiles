{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "hidden": true
    },
    "explore": {
      "model": "{env:OPENCODE_HAIKU_MODEL}"
    },
    "plan": {
      "hidden": true
    },
    "einstein": {
      "color": "#5d77ea",
      "model": "{env:OPENCODE_OPUS_MODEL}",
      "permission": {
        "bash": {
          "*": "allow",
          "> *": "ask",
          "chmod *": "ask",
          "chown *": "ask",
          "dd *": "ask",
          "gh *": "ask",
          "gh api *": "allow",
          "gh issue list*": "allow",
          "gh issue view*": "allow",
          "gh pr checks*": "allow",
          "gh pr diff*": "allow",
          "gh pr list*": "allow",
          "gh pr status*": "allow",
          "gh pr view*": "allow",
          "gh release list*": "allow",
          "gh release view*": "allow",
          "gh repo view*": "allow",
          "gh run list*": "allow",
          "gh run view*": "allow",
          "gh search *": "allow",
          "gh status*": "allow",
          "git branch -D*": "ask",
          "git checkout -- *": "ask",
          "git clean*": "ask",
          "git commit*": "ask",
          "git push --force*": "ask",
          "git push*": "ask",
          "git reset --hard*": "ask",
          "git restore *": "ask",
          "git stash drop*": "ask",
          "kill *": "ask",
          "killall *": "ask",
          "mv *": "ask",
          "pkill *": "ask",
          "rm *": "ask",
          "rm -f*": "ask",
          "rm -r*": "ask",
          "rmdir *": "ask",
          "shred *": "ask",
          "sudo *": "ask",
          "truncate *": "ask"
        },
        "edit": "allow"
      },
      "temperature": 0.3
    },
    "soulja-boy": {
      "color": "#bf8c78",
      "model": "{env:OPENCODE_SONNET_MODEL}",
      "permission": {
        "bash": {
          "*": "allow",
          "> *": "ask",
