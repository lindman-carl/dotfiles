          "git reset --hard*": "ask",
          "git restore *": "ask",
          "git stash": "allow",
          "git stash drop*": "ask",
          "git stash list*": "allow",
          "git stash pop*": "allow",
          "git stash push*": "allow",
          "kill *": "ask",
          "killall *": "ask",
          "mv *": "ask",
          "pkill *": "ask",
          "rm *": "ask",
          "rm -f*": "ask",
          "rm -r*": "ask",
          "rmdir *": "ask",
          "shred *": "ask",
          "sudo *": "ask",
          "truncate *": "ask"
        },
        "edit": "allow"
      },
      "temperature": 0.3
    },
    "sickan": {
      "model": "{env:OPENCODE_OPUS_MODEL}",
      "permission": {
        "bash": {
          "*": "deny",
          "cat *": "allow",
          "du *": "allow",
          "echo *": "allow",
          "fd *": "allow",
          "file *": "allow",
          "find *": "allow",
          "gh api *": "allow",
          "gh issue list*": "allow",
          "gh issue view*": "allow",
          "gh pr checks*": "allow",
          "gh pr diff*": "allow",
          "gh pr list*": "allow",
          "gh pr status*": "allow",
          "gh pr view*": "allow",
          "gh release list*": "allow",
          "gh release view*": "allow",
          "gh repo view*": "allow",
          "gh run list*": "allow",
          "gh run view*": "allow",
          "gh search *": "allow",
          "gh status*": "allow",
          "git branch": "allow",
          "git branch *": "allow",
          "git diff": "allow",
