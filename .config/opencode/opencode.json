          "git reset --hard*": "ask",
          "git restore *": "ask",
          "git stash drop*": "ask",
          "kill *": "ask",
          "killall *": "ask",
          "mv *": "ask",
          "pkill *": "ask",
          "rm *": "ask",
          "rm -f*": "ask",
          "rm -r*": "ask",
          "rmdir *": "ask",
          "shred *": "ask",
          "sudo *": "ask",
          "truncate *": "ask"
        },
        "edit": "ask"
      },
      "temperature": 0.3
    }
  },
  "compaction": {
    "auto": true
  },
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "playwright": {
      "command": [
        "npx",
        "@playwright/mcp@latest",
        "--extension"
      ],
      "enabled": true,
      "type": "local"
    },
    "trigger": {
      "command": [
        "npx",
        "trigger.dev@4.3.2",
        "mcp"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "disabled_providers": [
    "azure",
    "azure-cognitive-services"
  ],
  "instructions": [
    "instructions.md"
  ],
  "model": "{env:OPENCODE_SONNET_MODEL}",
  "plugin": [
    "@mohak34/opencode-notifier@latest",
    "opencode-wakatime"
  ],
  "share": "disabled",
  "small_model": "{env:OPENCODE_HAIKU_MODEL}",
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**",
      ".next/**",
      "coverage/**",
      "*.log"
    ]
  }
}