          "tail *": "allow",
          "tree": "allow",
          "tree *": "allow",
          "wc *": "allow",
          "which *": "allow"
        }
      },
      "temperature": 0.1,
      "tools": {
        "edit": false,
        "write": false
      }
    },
    "speed": {
      "color": "#22C55E",
      "model": "{env:OPENCODE_HAIKU_MODEL}",
      "permission": {
        "bash": {
          "*": "allow",
          "> *": "ask",
          "chmod *": "ask",
          "chown *": "ask",
          "dd *": "ask",
          "gh *": "ask",
          "gh api *": "allow",
          "gh issue list*": "allow",
