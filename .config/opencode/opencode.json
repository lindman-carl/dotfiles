          "gh pr checks*": "allow",
          "gh pr diff*": "allow",
          "gh pr list*": "allow",
          "gh pr status*": "allow",
          "gh pr view*": "allow",
          "gh release list*": "allow",
          "gh release view*": "allow",
          "gh repo view*": "allow",
          "gh run list*": "allow",
          "gh run view*": "allow",
          "gh search *": "allow",
          "gh status*": "allow",
          "git add*": "allow",
          "git branch -D*": "ask",
          "git checkout -- *": "ask",
